# ReservaPlay environment example
# Copy to `.env` and fill real secret values for local development

PORT=3000

# Postgres connection
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=postgres
DB_NAME=reservaplay
# JWT settings
JWT_SECRET=ReservaplaySecretKey
JWT_EXPIRES_IN=3600s
